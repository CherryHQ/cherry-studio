{
  "version": 1,
  "contract": "shadcn-v2",
  "defaultKind": "css-custom-property",
  "exclude": [
    "packages/ui/src/styles/theme.css",
    "packages/ui/src/styles/contract.css",
    "packages/ui/src/styles/shadcn.css",
    "packages/ui/src/styles/product.css",
    "packages/ui/src/styles/tokens/**",
    "packages/ui/src/styles/migrations/**",
    "src/renderer/assets/styles/legacy-vars.css",
    "src/renderer/assets/styles/tailwind.css",
    "**/dist/**",
    "**/node_modules/**",
    "**/*.snap"
  ],
  "rules": [
    { "source": "--cs-background", "target": "--background", "strategy": "exact" },
    { "source": "--cs-foreground", "target": "--foreground", "strategy": "exact" },
    { "source": "--cs-card", "target": "--card", "strategy": "exact" },
    { "source": "--cs-card-foreground", "target": "--card-foreground", "strategy": "exact" },
    { "source": "--cs-popover", "target": "--popover", "strategy": "exact" },
    { "source": "--cs-popover-foreground", "target": "--popover-foreground", "strategy": "exact" },
    {
      "source": "--cs-primary",
      "target": "--primary",
      "strategy": "contextual",
      "reason": "The canonical variable participates in runtime user-theme overrides while the old value does not."
    },
    { "source": "--cs-primary-foreground", "target": "--primary-foreground", "strategy": "exact" },
    { "source": "--cs-secondary", "target": "--secondary", "strategy": "exact" },
    { "source": "--cs-secondary-foreground", "target": "--secondary-foreground", "strategy": "exact" },
    { "source": "--cs-muted", "target": "--muted", "strategy": "exact" },
    { "source": "--cs-foreground-secondary", "target": "--cs-text-secondary", "strategy": "exact" },
    { "source": "--cs-muted-foreground", "target": "--muted-foreground", "strategy": "exact" },
    { "source": "--cs-accent", "target": "--accent", "strategy": "exact" },
    { "source": "--cs-accent-foreground", "target": "--accent-foreground", "strategy": "exact" },
    { "source": "--cs-destructive", "target": "--destructive", "strategy": "exact" },
    {
      "source": "--cs-destructive-foreground",
      "target": "--destructive-foreground",
      "strategy": "exact"
    },
    { "source": "--cs-border", "target": "--border", "strategy": "exact" },
    { "source": "--cs-input", "target": "--input", "strategy": "exact" },
    {
      "source": "--cs-ring",
      "target": "--ring",
      "strategy": "contextual",
      "reason": "The canonical ring derives from the runtime primary input."
    },
    { "source": "--cs-sidebar", "target": "--sidebar", "strategy": "exact" },
    { "source": "--cs-sidebar-foreground", "target": "--sidebar-foreground", "strategy": "exact" },
    { "source": "--cs-sidebar-primary", "target": "--sidebar-primary", "strategy": "exact" },
    {
      "source": "--cs-sidebar-primary-foreground",
      "target": "--sidebar-primary-foreground",
      "strategy": "exact"
    },
    { "source": "--cs-sidebar-accent", "target": "--sidebar-accent", "strategy": "exact" },
    {
      "source": "--cs-sidebar-accent-foreground",
      "target": "--sidebar-accent-foreground",
      "strategy": "exact"
    },
    { "source": "--cs-sidebar-border", "target": "--sidebar-border", "strategy": "exact" },
    { "source": "--cs-sidebar-ring", "target": "--sidebar-ring", "strategy": "exact" },
    {
      "source": "--cs-border-hover",
      "target": "--cs-border-strong",
      "strategy": "contextual",
      "contexts": ["border-color"],
      "reason": "Hover-state usage must remain a component state instead of becoming a static strong border."
    },
    {
      "source": "--cs-foreground-muted",
      "target": null,
      "strategy": "review",
      "contexts": ["color", "fill", "stroke"],
      "reason": "The old token mixes tertiary content with disabled component state."
    },
    { "source": "--cs-error-base", "target": "--cs-error", "strategy": "exact" },
    { "source": "--cs-error-text", "target": "--cs-error-subtle-foreground", "strategy": "exact" },
    { "source": "--cs-error-bg", "target": "--cs-error-subtle", "strategy": "exact" },
    { "source": "--cs-success-base", "target": "--cs-success", "strategy": "exact" },
    { "source": "--cs-success-bg", "target": "--cs-success-subtle", "strategy": "exact" },
    {
      "source": "--cs-warning-base",
      "target": "--cs-warning",
      "strategy": "contextual",
      "reason": "The legacy light-mode base uses amber-400 while the product warning token uses amber-500."
    },
    { "source": "--cs-warning-bg", "target": "--cs-warning-subtle", "strategy": "exact" },
    { "source": "--cs-info-base", "target": "--cs-info", "strategy": "exact" },
    { "source": "--cs-info-bg", "target": "--cs-info-subtle", "strategy": "exact" },
    { "source": "--color-text-1", "target": "--cs-text-primary", "strategy": "exact" },
    { "source": "--color-text-2", "target": "--cs-text-secondary", "strategy": "exact" },
    { "source": "--color-text-3", "target": "--cs-text-tertiary", "strategy": "exact" },
    { "source": "--color-text", "target": "--cs-text-primary", "strategy": "exact" },
    { "source": "--color-text-secondary", "target": "--cs-text-secondary", "strategy": "exact" },
    { "source": "--color-text-soft", "target": "--cs-text-secondary", "strategy": "exact" },
    { "source": "--color-text-light", "target": "--cs-text-light", "strategy": "exact" },
    { "source": "--color-background-soft", "target": "--cs-background-soft", "strategy": "exact" },
    { "source": "--color-background-mute", "target": "--cs-background-muted", "strategy": "exact" },
    {
      "source": "--color-background-opacity",
      "target": "--cs-background-translucent",
      "strategy": "exact"
    },
    { "source": "--color-border-soft", "target": "--cs-border-soft", "strategy": "exact" },
    { "source": "--color-border-mute", "target": "--cs-border-faint", "strategy": "exact" },
    { "source": "--color-error", "target": "--cs-error", "strategy": "exact" },
    { "source": "--color-link", "target": "--cs-link", "strategy": "exact" },
    { "source": "--color-primary-bg", "target": "--cs-primary-soft", "strategy": "exact" },
    { "source": "--color-fill-secondary", "target": "--cs-fill-secondary", "strategy": "exact" },
    { "source": "--color-fill-2", "target": "--cs-fill-secondary", "strategy": "exact" },
    { "source": "--color-bg-base", "target": "--background", "strategy": "exact" },
    { "source": "--color-bg-1", "target": "--cs-background-soft", "strategy": "exact" },
    { "source": "--color-code-background", "target": "--cs-code-block", "strategy": "exact" },
    {
      "source": "--color-inline-code-background",
      "target": "--cs-inline-code",
      "strategy": "exact"
    },
    {
      "source": "--color-inline-code-text",
      "target": "--cs-inline-code-foreground",
      "strategy": "exact"
    },
    { "source": "--color-hover", "target": "--cs-interactive-hover", "strategy": "exact" },
    { "source": "--color-active", "target": "--cs-interactive-active", "strategy": "exact" },
    { "source": "--color-frame-border", "target": "--cs-frame-border", "strategy": "exact" },
    {
      "source": "--color-group-background",
      "target": "--cs-group-background",
      "strategy": "exact"
    },
    { "source": "--color-reference", "target": "--cs-reference", "strategy": "exact" },
    {
      "source": "--color-reference-text",
      "target": "--cs-reference-foreground",
      "strategy": "exact"
    },
    {
      "source": "--color-reference-background",
      "target": "--cs-reference-subtle",
      "strategy": "exact"
    },
    { "source": "--color-list-item", "target": "--cs-list-item", "strategy": "exact" },
    { "source": "--color-list-item-hover", "target": "--cs-list-item-hover", "strategy": "exact" },
    { "source": "--color-highlight", "target": "--cs-highlight-foreground", "strategy": "exact" },
    {
      "source": "--color-background-highlight",
      "target": "--cs-highlight",
      "strategy": "exact"
    },
    {
      "source": "--color-background-highlight-accent",
      "target": "--cs-highlight-accent",
      "strategy": "exact"
    },
    {
      "source": "--navbar-background-mac",
      "target": "--cs-navbar-translucent",
      "strategy": "exact"
    },
    { "source": "--navbar-background", "target": "--cs-navbar", "strategy": "exact" },
    { "source": "--modal-background", "target": "--cs-modal", "strategy": "exact" },
    { "source": "--chat-background", "target": "--cs-chat", "strategy": "exact" },
    { "source": "--chat-background-user", "target": "--cs-chat-user", "strategy": "exact" },
    {
      "source": "--chat-background-assistant",
      "target": "--cs-chat-assistant",
      "strategy": "exact"
    },
    { "source": "--chat-text-user", "target": "--cs-chat-user-foreground", "strategy": "exact" },
    { "source": "--list-item-border-radius", "target": "--cs-list-item-radius", "strategy": "exact" },
    { "source": "--color-gray-1", "target": "--cs-system-gray-1", "strategy": "exact" },
    { "source": "--color-gray-2", "target": "--cs-system-gray-2", "strategy": "exact" },
    { "source": "--color-gray-3", "target": "--cs-system-gray-3", "strategy": "exact" },
    { "source": "--color-icon-white", "target": "--cs-icon-contrast", "strategy": "exact" },
    { "source": "--color-primary-1", "target": "--cs-primary-subtle", "strategy": "exact" },
    { "source": "--color-primary-6", "target": "--primary", "strategy": "exact" },
    { "source": "--color-status-success", "target": "--cs-success", "strategy": "exact" },
    { "source": "--color-status-error", "target": "--cs-error", "strategy": "exact" },
    { "source": "--color-status-warning", "target": "--cs-warning", "strategy": "exact" },
    { "source": "--app-icon", "target": "--cs-icon", "strategy": "exact" },
    { "source": "--app-sidebar", "target": "--sidebar", "strategy": "exact" },
    { "source": "--app-sidebar-accent", "target": "--sidebar-accent", "strategy": "exact" },
    { "source": "--app-sidebar-foreground", "target": "--sidebar-foreground", "strategy": "exact" },
    { "source": "--app-sidebar-active-bg", "target": "--cs-sidebar-active-bg", "strategy": "exact" },
    {
      "source": "--app-sidebar-active-border",
      "target": "--cs-sidebar-active-border",
      "strategy": "exact"
    },
    { "source": "--app-sidebar-glow-bg", "target": "--cs-sidebar-glow-bg", "strategy": "exact" },
    {
      "source": "--app-sidebar-glow-line",
      "target": "--cs-sidebar-glow-line",
      "strategy": "exact"
    },
    { "source": "--app-sidebar-primary", "target": "--sidebar-primary", "strategy": "exact" },
    {
      "source": "--app-sidebar-primary-foreground",
      "target": "--sidebar-primary-foreground",
      "strategy": "exact"
    },
    {
      "source": "--app-sidebar-accent-foreground",
      "target": "--sidebar-accent-foreground",
      "strategy": "exact"
    },
    { "source": "--app-sidebar-border", "target": "--sidebar-border", "strategy": "exact" },
    { "source": "--app-sidebar-ring", "target": "--sidebar-ring", "strategy": "exact" },
    { "source": "--app-primary-foreground", "target": "--primary-foreground", "strategy": "exact" },
    { "source": "--app-card-foreground", "target": "--card-foreground", "strategy": "exact" },
    { "source": "--app-popover-foreground", "target": "--popover-foreground", "strategy": "exact" },
    {
      "source": "--app-secondary-foreground",
      "target": "--secondary-foreground",
      "strategy": "exact"
    },
    { "source": "--app-muted-foreground", "target": "--muted-foreground", "strategy": "exact" },
    { "source": "--app-accent-foreground", "target": "--accent-foreground", "strategy": "exact" },
    {
      "source": "--app-destructive-foreground",
      "target": "--destructive-foreground",
      "strategy": "exact"
    },
    { "source": "--app-input", "target": "--input", "strategy": "exact" }
  ]
}
