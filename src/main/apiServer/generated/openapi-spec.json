{
  "components": {
    "schemas": {
      "ChatCompletionRequest": {
        "properties": {
          "max_tokens": {
            "minimum": 1,
            "type": "integer"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "type": "array"
          },
          "model": {
            "description": "The model to use for completion, in format provider:model-id",
            "type": "string"
          },
          "stream": {
            "default": false,
            "type": "boolean"
          },
          "temperature": {
            "default": 1,
            "maximum": 2,
            "minimum": 0,
            "type": "number"
          },
          "tools": {
            "items": {
              "properties": {
                "function": {
                  "properties": {
                    "description": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "parameters": {
                      "type": "object"
                    }
                  },
                  "type": "object"
                },
                "type": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": ["model", "messages"],
        "type": "object"
      },
      "ChatMessage": {
        "properties": {
          "content": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "items": {
                  "properties": {
                    "image_url": {
                      "properties": {
                        "url": {
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "text": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "type": "array"
              }
            ]
          },
          "name": {
            "type": "string"
          },
          "role": {
            "enum": ["system", "user", "assistant", "tool"],
            "type": "string"
          },
          "tool_calls": {
            "items": {
              "properties": {
                "function": {
                  "properties": {
                    "arguments": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "id": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "Error": {
        "properties": {
          "error": {
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "type": "object"
          }
        },
        "type": "object"
      },
      "KnowledgeBaseEntity": {
        "properties": {
          "chunkOverlap": {
            "description": "Overlap between chunks",
            "type": "integer"
          },
          "chunkSize": {
            "description": "Chunk size for document splitting",
            "type": "integer"
          },
          "created_at": {
            "description": "Creation timestamp",
            "type": "number"
          },
          "description": {
            "description": "Knowledge base description",
            "type": "string"
          },
          "dimensions": {
            "description": "Embedding dimensions",
            "type": "integer"
          },
          "documentCount": {
            "description": "Number of documents",
            "type": "integer"
          },
          "id": {
            "description": "Unique knowledge base identifier",
            "type": "string"
          },
          "items": {
            "description": "Knowledge items",
            "items": {
              "type": "object"
            },
            "type": "array"
          },
          "model": {
            "description": "Embedding model configuration",
            "properties": {
              "id": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "name": {
            "description": "Knowledge base name",
            "type": "string"
          },
          "preprocessProvider": {
            "description": "Preprocess provider configuration",
            "properties": {
              "provider": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "rerankModel": {
            "description": "Rerank model configuration",
            "properties": {
              "id": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "threshold": {
            "description": "Similarity threshold",
            "type": "number"
          },
          "updated_at": {
            "description": "Last update timestamp",
            "type": "number"
          },
          "version": {
            "description": "Schema version",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "KnowledgeSearchResult": {
        "properties": {
          "knowledge_base_id": {
            "description": "Source knowledge base ID",
            "type": "string"
          },
          "knowledge_base_name": {
            "description": "Source knowledge base name",
            "type": "string"
          },
          "metadata": {
            "description": "Document metadata",
            "type": "object"
          },
          "pageContent": {
            "description": "Document chunk content",
            "type": "string"
          },
          "score": {
            "description": "Similarity score",
            "type": "number"
          }
        },
        "type": "object"
      },
      "ListKnowledgeBasesResponse": {
        "properties": {
          "knowledge_bases": {
            "items": {
              "$ref": "#/components/schemas/KnowledgeBaseEntity"
            },
            "type": "array"
          },
          "total": {
            "description": "Total number of knowledge bases",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "MCPServer": {
        "properties": {
          "args": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "command": {
            "type": "string"
          },
          "disabled": {
            "type": "boolean"
          },
          "env": {
            "type": "object"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "Model": {
        "properties": {
          "created": {
            "type": "integer"
          },
          "id": {
            "type": "string"
          },
          "object": {
            "enum": ["model"],
            "type": "string"
          },
          "owned_by": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "SearchKnowledgeRequest": {
        "properties": {
          "document_count": {
            "default": 5,
            "description": "Maximum number of results to return",
            "maximum": 20,
            "minimum": 1,
            "type": "integer"
          },
          "knowledge_base_ids": {
            "description": "Optional list of knowledge base IDs to search. If not provided, searches all knowledge bases.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "query": {
            "description": "Search query text",
            "maxLength": 1000,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": ["query"],
        "type": "object"
      },
      "SearchKnowledgeResponse": {
        "properties": {
          "query": {
            "description": "The original search query",
            "type": "string"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/KnowledgeSearchResult"
            },
            "type": "array"
          },
          "searched_bases": {
            "description": "Knowledge bases that were searched",
            "items": {
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "type": "array"
          },
          "total": {
            "description": "Total number of results",
            "type": "integer"
          },
          "warnings": {
            "description": "Warning messages for partial search failures",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "bearerFormat": "JWT",
        "description": "Use the API key from Cherry Studio settings",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Cherry Studio",
      "url": "https://github.com/CherryHQ/cherry-studio"
    },
    "description": "OpenAI-compatible API for Cherry Studio with additional Cherry-specific endpoints",
    "title": "Cherry Studio API",
    "version": "1.0.0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "description": "Get basic API information and available endpoints",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "endpoints": {
                      "type": "object"
                    },
                    "name": {
                      "example": "Cherry Studio API",
                      "type": "string"
                    },
                    "version": {
                      "example": "1.0.0",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "API information"
          }
        },
        "security": [],
        "summary": "API information",
        "tags": ["General"]
      }
    },
    "/health": {
      "get": {
        "description": "Check server status (no authentication required)",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "example": "ok",
                      "type": "string"
                    },
                    "timestamp": {
                      "format": "date-time",
                      "type": "string"
                    },
                    "version": {
                      "example": "1.0.0",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Server is healthy"
          }
        },
        "security": [],
        "summary": "Health check endpoint",
        "tags": ["Health"]
      }
    },
    "/v1/chat/completions": {
      "post": {
        "description": "Create a chat completion response, compatible with OpenAI API",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "choices": {
                      "items": {
                        "properties": {
                          "finish_reason": {
                            "type": "string"
                          },
                          "index": {
                            "type": "integer"
                          },
                          "message": {
                            "$ref": "#/components/schemas/ChatMessage"
                          }
                        },
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "created": {
                      "type": "integer"
                    },
                    "id": {
                      "type": "string"
                    },
                    "model": {
                      "type": "string"
                    },
                    "object": {
                      "example": "chat.completion",
                      "type": "string"
                    },
                    "usage": {
                      "properties": {
                        "completion_tokens": {
                          "type": "integer"
                        },
                        "prompt_tokens": {
                          "type": "integer"
                        },
                        "total_tokens": {
                          "type": "integer"
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              },
              "text/event-stream": {
                "schema": {
                  "description": "Server-sent events stream (when stream=true)",
                  "type": "string"
                }
              }
            },
            "description": "Chat completion response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Bad request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Unauthorized"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Rate limit exceeded"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "summary": "Create chat completion",
        "tags": ["Chat"]
      }
    },
    "/v1/knowledge-bases": {
      "get": {
        "description": "Returns a list of all configured knowledge bases",
        "parameters": [
          {
            "description": "Number of knowledge bases to return",
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 20,
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Number of knowledge bases to skip",
            "in": "query",
            "name": "offset",
            "schema": {
              "default": 0,
              "minimum": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListKnowledgeBasesResponse"
                }
              }
            },
            "description": "List of knowledge bases"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Service unavailable (Redux store not accessible)"
          }
        },
        "summary": "List all knowledge bases",
        "tags": ["Knowledge"]
      }
    },
    "/v1/knowledge-bases/search": {
      "post": {
        "description": "Search across one or more knowledge bases and retrieve relevant document chunks.\n\nEach result includes:\n- `pageContent`: The text content of the matching chunk\n- `score`: Similarity score (higher = more relevant)\n- `metadata`: Additional information about the source document\n- `knowledge_base_id` & `knowledge_base_name`: Source of the result\n\nResults are sorted by relevance score in descending order.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "document_count": 5,
                "knowledge_base_ids": ["kb-uuid-1", "kb-uuid-2"],
                "query": "How do I configure Ollama embedding?"
              },
              "schema": {
                "$ref": "#/components/schemas/SearchKnowledgeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "query": "Ollama embedding config",
                  "results": [
                    {
                      "knowledge_base_id": "kb-uuid-1",
                      "knowledge_base_name": "My Docs",
                      "metadata": {
                        "source": "/path/to/doc.md",
                        "type": "file"
                      },
                      "pageContent": "To use Ollama embeddings, set the base URL to http://localhost:11434",
                      "score": 0.89
                    }
                  ],
                  "searched_bases": [
                    {
                      "id": "kb-uuid-1",
                      "name": "My Docs"
                    }
                  ],
                  "total": 1
                },
                "schema": {
                  "$ref": "#/components/schemas/SearchKnowledgeResponse"
                }
              }
            },
            "description": "Search results"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid request"
          },
          "502": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "All knowledge base searches failed"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Service unavailable (Redux store not accessible)"
          }
        },
        "summary": "Search knowledge bases",
        "tags": ["Knowledge"]
      }
    },
    "/v1/knowledge-bases/{id}": {
      "get": {
        "parameters": [
          {
            "description": "Knowledge base ID",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeBaseEntity"
                }
              }
            },
            "description": "Knowledge base details"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Knowledge base not found"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Service unavailable (Redux store not accessible)"
          }
        },
        "summary": "Get a knowledge base by ID",
        "tags": ["Knowledge"]
      }
    },
    "/v1/mcps": {
      "get": {
        "description": "Get a list of all configured Model Context Protocol servers",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "data": {
                      "items": {
                        "$ref": "#/components/schemas/MCPServer"
                      },
                      "type": "array"
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "List of MCP servers"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "$ref": "#/components/schemas/Error"
                    },
                    "success": {
                      "example": false,
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Service unavailable"
          }
        },
        "summary": "List MCP servers",
        "tags": ["MCP"]
      }
    },
    "/v1/mcps/{server_id}": {
      "get": {
        "description": "Get detailed information about a specific MCP server",
        "parameters": [
          {
            "description": "MCP server ID",
            "in": "path",
            "name": "server_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/MCPServer"
                    },
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "MCP server information"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "$ref": "#/components/schemas/Error"
                    },
                    "success": {
                      "example": false,
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "MCP server not found"
          }
        },
        "summary": "Get MCP server info",
        "tags": ["MCP"]
      }
    },
    "/v1/messages": {
      "post": {
        "description": "Create a message response using Anthropic's API format",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "max_tokens": {
                    "description": "Maximum number of tokens to generate",
                    "example": 1024,
                    "minimum": 1,
                    "type": "integer"
                  },
                  "messages": {
                    "items": {
                      "properties": {
                        "content": {
                          "oneOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "array"
                            }
                          ]
                        },
                        "role": {
                          "enum": ["user", "assistant"],
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "model": {
                    "description": "Model ID in format \"providerId::modelId\"",
                    "example": "my-anthropic:claude-3-5-sonnet-20241022",
                    "type": "string"
                  },
                  "stream": {
                    "description": "Whether to stream the response",
                    "type": "boolean"
                  },
                  "system": {
                    "description": "System message",
                    "type": "string"
                  },
                  "temperature": {
                    "description": "Sampling temperature",
                    "maximum": 1,
                    "minimum": 0,
                    "type": "number"
                  },
                  "tools": {
                    "description": "Available tools for the model",
                    "type": "array"
                  },
                  "top_k": {
                    "description": "Top-k sampling",
                    "minimum": 0,
                    "type": "integer"
                  },
                  "top_p": {
                    "description": "Nucleus sampling",
                    "maximum": 1,
                    "minimum": 0,
                    "type": "number"
                  }
                },
                "required": ["model", "max_tokens", "messages"],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "content": {
                      "items": {
                        "type": "object"
                      },
                      "type": "array"
                    },
                    "id": {
                      "type": "string"
                    },
                    "model": {
                      "type": "string"
                    },
                    "role": {
                      "example": "assistant",
                      "type": "string"
                    },
                    "stop_reason": {
                      "type": "string"
                    },
                    "stop_sequence": {
                      "type": "string"
                    },
                    "type": {
                      "example": "message",
                      "type": "string"
                    },
                    "usage": {
                      "properties": {
                        "input_tokens": {
                          "type": "integer"
                        },
                        "output_tokens": {
                          "type": "integer"
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              },
              "text/event-stream": {
                "schema": {
                  "description": "Server-sent events stream (when stream=true)",
                  "type": "string"
                }
              }
            },
            "description": "Message response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "properties": {
                        "message": {
                          "type": "string"
                        },
                        "type": {
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "type": {
                      "example": "error",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
